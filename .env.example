# ──────────────────────────────────────────────────────────────
# Manumation Snapshot — environment configuration
# Copy to .env and fill in. Never commit real secrets.
# ──────────────────────────────────────────────────────────────

# Server
PORT=8080
NODE_ENV=development

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@localhost:5432/manumation

# Anthropic (Claude) — the relationship intelligence engine
ANTHROPIC_API_KEY=sk-ant-...
# Override the model if needed. Defaults to claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# Go High Level — v1 uses a private integration token
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_TOKEN=
GHL_LOCATION_ID=
# Optional shared secret to verify inbound webhooks from GHL
GHL_WEBHOOK_SECRET=

# Humanity threshold — replies scoring below this are rejected/rewritten
HUMANITY_THRESHOLD=95

# The sender this build is optimized for (v1 = Jeremy)
SENDER_NAME=Jeremy Kean

# ── Dashboard auth (single-user, v1) ──────────────────────────────────────
# Set a password to gate the dashboard + API. If unset, the app runs OPEN.
APP_PASSWORD=
# Secret used to sign session tokens. Set a long random string in production.
# If unset, a value is derived from APP_PASSWORD.
AUTH_SECRET=
# Session lifetime in hours (default 168 = 7 days).
AUTH_SESSION_HOURS=168
